# Copy this file to .env.production and fill in the values before deploying.
# Generate a strong JWT secret: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_use_openssl_rand_base64_32

# Public URLs — must be reachable by the browser (not Docker-internal).
# Override with the host IP or domain when deploying to a remote machine.
# Example for a LAN Raspberry Pi:
#   WEB_ORIGIN=http://192.168.0.105:3000
#   API_URL=http://192.168.0.105:3001
WEB_ORIGIN=http://localhost:3000
API_URL=http://localhost:3001
